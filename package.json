{
  "name": "deckflix",
  "private": true,
  "catalog": {
    "zod": "^3.24.0"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --filter @deckflix/server dev",
    "dev:web": "bun run --filter @deckflix/web dev",
    "build": "bun run --filter '*' build",
    "db:generate": "bun run --filter @deckflix/server db:generate",
    "db:migrate": "bun run --filter @deckflix/server db:migrate",
    "db:studio": "bun run --filter @deckflix/server db:studio"
  }
}
